# =============================================================================
# Singul-AH — variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commit o .env.local — ele contém credenciais reais.
# =============================================================================

# --- Supabase ------------------------------------------------------------------
VITE_SUPABASE_URL="https://<PROJECT_REF>.supabase.co"
VITE_SUPABASE_ANON_KEY="<chave anon pública do projeto>"

# --- URL do app (usada no gateway para CORS e em Edge Functions) ---------------
APP_URL="http://localhost:3000"

# --- Provedor de IA ------------------------------------------------------------
#
# AI_PROVIDER controla qual provedor de IA o gateway usa:
#   auto   — tenta Ollama local primeiro; se indisponível, usa Gemini (padrão)
#   ollama — somente Ollama (sem fallback) — RECOMENDADO para produção
#            Máxima privacidade LGPD: dados nunca saem da máquina.
#   gemini — somente Gemini (comportamento original)
#
AI_PROVIDER="auto"

# --- Ollama (IA local, zero custo, sem subprocessador externo) -----------------
#
# Instalar: brew install ollama  (macOS)
# Baixar modelo: ollama pull gemma3:4b   (~3 GB)
# Iniciar: ollama serve
#
# OLLAMA_BASE_URL — padrão: http://localhost:11434
# OLLAMA_MODEL    — padrão: gemma3:4b  (bom equilíbrio qualidade/velocidade)
#                   alternativa menor: gemma3:1b (~815 MB, mais rápido)
#
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="gemma3:4b"

# --- Gemini API (necessário apenas se AI_PROVIDER=gemini ou AI_PROVIDER=auto) --
#
# Obter em: https://aistudio.google.com/app/apikey
# AVISO: o tier gratuito do AI Studio pode usar prompts para melhorar produtos
# Google. Para compliance total com LGPD, prefira AI_PROVIDER=ollama ou
# contrate o tier pago / Vertex AI (com DPA formalizado).
#
GEMINI_API_KEY="MY_GEMINI_API_KEY"
